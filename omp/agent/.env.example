# omp (oh-my-pi) agent env — shared by HOST and CONTAINER (single source: agent_configs).
#
# Template only. `make install` seeds it to ~/.omp/agent/.env once and never
# overwrites it. omp's $env loader reads that file after the process env and
# project .env, so anything there applies to every omp session.
#
# The seeded copy is per-machine and never committed, so real secrets (API keys)
# may live there — or in ~/.omp/agent/models.yml (also gitignored).

# ANTHROPIC_API_KEY="sk-ant-..."

# ── Anthropic prompt caching ───────────────────────────────────────────────────
# Caching itself is automatic: omp's Anthropic client always places cache_control
# breakpoints (system + recent messages, up to 4) and derives prompt_cache_key from
# the session id. The only knob is retention: `long` asks for the 1h cache TTL instead
# of the default 5m, where the model + endpoint support it (real Anthropic API; OAuth
# logins already default to long). Harmless for API-key usage that doesn't support it.
PI_CACHE_RETENTION=long

# ── Streaming timeouts (the omp analogs of opencode's timeout / chunkTimeout) ────
# First-event timeout: how long to wait for the first token before aborting+retrying.
# opencode's `timeout: 3600000` is a whole-request budget; omp has no single overall
# timeout, so this (wait-for-first-token) is the closest analog. Default 100000.
PI_STREAM_FIRST_EVENT_TIMEOUT_MS=3600000
# Idle timeout: max gap between streamed events once flowing — the real stall watchdog.
# Mirrors opencode's `chunkTimeout: 60000`. Default 120000. Set 0 on either to disable.
PI_STREAM_IDLE_TIMEOUT_MS=60000
